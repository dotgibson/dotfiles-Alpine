# ~/.ssh/config
# Managed via ~/dotfiles-Alpine/ssh/config → symlinked by bootstrap.sh.
# Keys themselves are NEVER tracked — .gitignore keeps only this file.
# Docs: man ssh_config

# =========================================================
# Global Defaults
# =========================================================
Host *
  # Connection multiplexing — reuse existing connections. Big win for repeated
  # SSH / lab / pentest sessions. bootstrap.sh creates ~/.ssh/sockets (0700).
  ControlMaster auto
  ControlPath ~/.ssh/sockets/%r@%h:%p
  ControlPersist 10m

  # Keep-alives so idle sessions don't silently drop
  ServerAliveInterval 60
  ServerAliveCountMax 3

  # Security hardening
  StrictHostKeyChecking ask
  VerifyHostKeyDNS yes
  HashKnownHosts yes
  AddKeysToAgent yes

  # 1Password SSH agent (optional). Comment IN if you use it on a Linux desktop:
  # IdentityAgent ~/.1password/agent.sock

  # Prefer modern algorithms
  KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,ecdh-sha2-nistp521
  HostKeyAlgorithms ssh-ed25519,ecdsa-sha2-nistp521,rsa-sha2-512
  Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
  MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com

  # Forward SSH agent / X11 only where explicitly set per-host
  ForwardAgent no
  ForwardX11 no

# =========================================================
# GitHub  (uses the key you generate: ~/.ssh/id_ed25519)
# =========================================================
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
  AddKeysToAgent yes

# =========================================================
# GitLab  (template — uncomment + add a key if you use it)
# =========================================================
# Host gitlab.com
#   HostName gitlab.com
#   User git
#   IdentityFile ~/.ssh/id_ed25519_gitlab
#   AddKeysToAgent yes

# =========================================================
# Jump Host / Bastion Template
# =========================================================
# Host bastion
#   HostName <bastion-ip-or-hostname>
#   User <your-username>
#   IdentityFile ~/.ssh/id_ed25519_work
#   ForwardAgent yes
#
# Host *.internal
#   ProxyJump bastion
#   User <your-username>
#   IdentityFile ~/.ssh/id_ed25519_work

# =========================================================
# Lab / Work Environment Template
# =========================================================
# Host lab-*
#   User root
#   IdentityFile ~/.ssh/id_ed25519_lab
#   StrictHostKeyChecking no       # ONLY for known throwaway lab machines
#   UserKnownHostsFile /dev/null

# =========================================================
# Personal VPS / Servers
# =========================================================
# Host myserver
#   HostName <ip>
#   User <user>
#   Port 22
#   IdentityFile ~/.ssh/id_ed25519_personal
